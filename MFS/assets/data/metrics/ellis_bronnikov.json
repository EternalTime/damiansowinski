        "\\ddot{\\theta} = -\\dfrac{2r}{r^2+\\ell^2}\\dot{r}\\dot{\\theta} + \\sin\\theta\\cos\\theta\\,\\dot{\\phi}^2",
        "\\ddot{\\phi} = -\\dfrac{2r}{r^2+\\ell^2}\\dot{r}\\dot{\\phi} - 2\\cot\\theta\\,\\dot{\\theta}\\dot{\\phi}"
      ]
    }
  ]
}